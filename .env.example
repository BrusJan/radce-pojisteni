# Frontend deployment
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_PAGES_PROJECT=your_cloudflare_pages_project
FRONTEND_API_BASE_URL=https://api.example.com

# VPS deployment
VPS_HOST=your.vps.host
VPS_USER=ubuntu
VPS_SSH_PORT=22
VPS_DEPLOY_PATH=/opt/insurance-advisor

# Backend and DB runtime
BACKEND_PORT=8080
APP_CORS_ALLOWED_ORIGINS=https://your-cloudflare-pages-domain.pages.dev
POSTGRES_DB=insurance_advisor
POSTGRES_USER=insurance_app
POSTGRES_PASSWORD=replace_me_securely
POSTGRES_PORT=5432
